# Kopieer naar .env en vul in. NOOIT committen.
# NATS_DAEMON_PASS kopieer je uit /opt/nats-jetstream/.env op mgmt01:
#   sudo grep "^NATS_DAEMON_PASS=" /opt/nats-jetstream/.env >> .env

NATS_URL=nats://nats:4222
NATS_USER=control-daemon
NATS_DAEMON_PASS=VEREIST_KOPIEER_UIT_DAEMON_ENV

REDIS_URL=redis://redis-session:6379/0
IDENTITY_BRIDGE_URL=http://identity-bridge:8088

# Scoring-spiegel — identiek houden aan de control-daemon (Verslag 35)
SCORE_WINDOW=600
SCORE_QUARANTINE=80
WEIGHT_MALWARE=80
WEIGHT_DLP=30
NETBIRD_POLICY_GROUPS=Studenten,Docenten,Admins

DB_PATH=/data/soc.db
RETENTION_DAYS=30
SCORE_POLL_INTERVAL=2.0
HTTP_PORT=8090
