# Kopieer naar .env — NOOIT committen.
# Vul aan met deze commando's op mgmt01:
#   sudo grep "^NATS_DAEMON_PASS=" /opt/nats-jetstream/.env >> .env
#   sudo grep "^NETBIRD_API_TOKEN=" /opt/control-daemon/.env >> .env
#   sudo grep "^NETBIRD_API_URL=" /opt/control-daemon/.env >> .env

NATS_URL=nats://nats:4222
NATS_USER=control-daemon
NATS_DAEMON_PASS=VEREIST

REDIS_URL=redis://redis-session:6379/0
IDENTITY_BRIDGE_URL=http://identity-bridge:8088

# Scoring — identiek aan control-daemon (Verslag 35)
SCORE_WINDOW=600
SCORE_QUARANTINE=80
WEIGHT_MALWARE=80
WEIGHT_DLP=30
NETBIRD_POLICY_GROUPS=Studenten,Docenten,Admins

# NetBird API (Fase 4b)
NETBIRD_API_URL=https://netbird.sandbox.local
NETBIRD_API_TOKEN=VEREIST
NETBIRD_QUARANTINE_GROUP_ID=d8ecpedv0c4s73aaq6s0
NETBIRD_CA_CERT=/certs/caddy-root.crt
NETBIRD_BREAK_GLASS=admin.1a,arne.vda,mgmt01

DB_PATH=/data/soc.db
RETENTION_DAYS=30
SCORE_POLL_INTERVAL=2.0
HTTP_PORT=8090

# Identity-bridge shared secret (X-Bridge-Secret header)
# Ophalen: sudo grep LOOKUP_SECRET $(docker inspect --format '{{.HostConfig.Binds}}' identity-bridge 2>/dev/null) 2>/dev/null
# Of direct: sudo docker inspect identity-bridge | python3 -c "import json,sys; [print(x) for x in json.load(sys.stdin)[0]['Config']['Env'] if 'LOOKUP' in x or 'SECRET' in x]"
IDENTITY_BRIDGE_SECRET=VEREIST
