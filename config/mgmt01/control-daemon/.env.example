# --- NATS (account-auth, bevestigd uit nats.conf accounts-blok) ---
NATS_URL=nats://nats-jetstream:4222
NATS_USER=control-daemon
NATS_PASS=                # = waarde van $NATS_DAEMON_PASS uit /opt/nats-jetstream/.env
# NATS_TOKEN=            # niet gebruiken: live config is accounts {}, geen token

# --- NetBird ---
NETBIRD_API_URL=https://netbird.sandbox.local/api
NETBIRD_API_TOKEN=       # service-PAT (zelfde als /opt/identity-bridge/.env)
NETBIRD_QUARANTINE_GROUP=Quarantine
NETBIRD_POLICY_GROUPS=Studenten,Docenten,Admins

# --- Redis ---
REDIS_URL=redis://redis-session:6379/0

# --- Fail-loud: CRITICAL-log is de eis; bus-emit uit (control-daemon-user mag het niet publiceren) ---
EMIT_ACTION_FAILED=false

# --- Enforcement: false = dry-run. Pas op true NA de testpeer-validatie. ---
ENFORCE=false
